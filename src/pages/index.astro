---
import MainLayout from "../layouts/MainLayout.astro";
import AppearanceWidget from "../components/AppearanceWidget.astro";
---

<MainLayout title="project-hikma | Digital Commons for Students">
  <!-- Hero Section -->
  <header class="relative min-h-[90vh] flex flex-col justify-center px-8 md:px-24 bg-surface overflow-hidden">
    <!-- Background decorations -->
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-5 pointer-events-none bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-primary to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-1/2 h-1/2 opacity-5 pointer-events-none bg-[radial-gradient(ellipse_at_bottom_left,_var(--tw-gradient-stops))] from-primary to-transparent"></div>

    <div class="grid grid-cols-12 gap-8 relative z-10">
      <div class="col-span-12 lg:col-span-9 xl:col-span-8">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-container text-on-primary-container text-xs font-label font-bold mb-6 border border-primary/20">
          <span class="material-symbols-outlined text-sm" data-icon="hub">hub</span>
          OPEN SOURCE KNOWLEDGE
        </div>
        <h1 class="font-headline text-6xl md:text-7xl lg:text-8xl xl:text-9xl font-bold tracking-tighter text-on-surface mb-8 leading-[1.05]">
          A Digital Commons <br /> <span class="text-primary">Built by Students.</span>
        </h1>
        <p class="text-on-surface-variant text-xl md:text-2xl max-w-3xl mb-12 leading-relaxed">
          More than just a repository. project-hikma is an academic knowledge base that grows through community refinement and introduces students to the power of open-source culture.
        </p>
        <p class="text-on-surface-variant text-sm md:text-base max-w-3xl mb-10 leading-relaxed">
          Disclaimer: this knowledge base is not official material from any college or university. It is a community-driven, open-source collection of contributions from students and maintainers.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            class="bg-primary text-on-primary px-8 py-4 rounded-xl font-medium text-lg hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/20 transition-all active:scale-95 flex items-center justify-center gap-3"
            href={`${import.meta.env.BASE_URL}/docs`}
          >
            <span class="material-symbols-outlined" data-icon="search">search</span>
            Explore the Archive
          </a>
          <a
            class="bg-surface-container border border-outline text-on-surface px-8 py-4 rounded-xl font-medium text-lg hover:bg-surface-container-high hover:border-outline-variant transition-all active:scale-95 flex items-center justify-center gap-3"
            href="https://github.com/ID-Brains/id-db/?tab=contributing-ov-file"
          >
            <span class="material-symbols-outlined" data-icon="edit_document">edit_document</span>
            Contribute Notes
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Quote Section -->
  <section class="py-24 px-8 md:px-24 bg-surface-container-lowest border-y border-outline-variant/20">
    <div class="max-w-4xl mx-auto text-center">
      <span class="material-symbols-outlined text-5xl text-primary/40 mb-6" data-icon="format_quote">format_quote</span>
      <h2 class="font-headline text-3xl md:text-5xl font-medium leading-tight text-on-surface mb-8">
        "Knowledge is the only treasure that increases when shared."
      </h2>
      <a href="https://github.com/ID-Brains/id-db/blob/main/docs/PHILOSOPHY.md" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-primary font-label font-bold hover:underline underline-offset-4">
        Read our full philosophy
        <span class="material-symbols-outlined text-sm" data-icon="arrow_forward">arrow_forward</span>
      </a>
    </div>
  </section>

  <!-- Core Pillars Section -->
  <section class="px-8 md:px-24 py-32 bg-surface">
    <div class="mb-20 max-w-3xl">
      <h2 class="font-headline text-4xl md:text-5xl font-bold tracking-tight mb-6 text-on-surface">
        Our Core Pillars
      </h2>
      <p class="text-xl text-on-surface-variant leading-relaxed">
        We believe that academic success should be accessible, collaborative, and community-driven. Our architecture and processes reflect these principles.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Pillar 1 -->
      <div class="bg-surface-container-low rounded-3xl p-8 lg:p-10 border border-outline/10 hover:border-primary/30 transition-colors flex flex-col group">
        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:-translate-y-1 group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-3xl text-primary" data-icon="accessibility_new">accessibility_new</span>
        </div>
        <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">Radical Accessibility</h3>
        <p class="text-on-surface-variant leading-relaxed flex-grow">
          Technical barriers shouldn't prevent sharing. We will offer a simple Web Form Flow alongside traditional Git workflows, ensuring anyone can contribute regardless of their technical background.
        </p>
      </div>

      <!-- Pillar 2 -->
      <div class="bg-surface-container-low rounded-3xl p-8 lg:p-10 border border-outline/10 hover:border-primary/30 transition-colors flex flex-col group">
        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:-translate-y-1 group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-3xl text-primary" data-icon="school">school</span>
        </div>
        <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">Open-Source Education</h3>
        <p class="text-on-surface-variant leading-relaxed flex-grow">
          A gateway to open-source culture. Students don't just share notes—they learn professional tools like Markdown, Git, and CI/CD in a high-impact, collaborative environment.
        </p>
      </div>

      <!-- Pillar 3 -->
      <div class="bg-surface-container-low rounded-3xl p-8 lg:p-10 border border-outline/10 hover:border-primary/30 transition-colors flex flex-col group">
        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:-translate-y-1 group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-3xl text-primary" data-icon="psychology">psychology</span>
        </div>
        <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">Popperian Refinement</h3>
        <p class="text-on-surface-variant leading-relaxed flex-grow">
          Knowledge is never static. Following Karl Popper's epistemology, we embrace errors as a step toward truth. Every Pull Request is an opportunity to refine and improve academic conjectures.
        </p>
      </div>

      <!-- Pillar 4 -->
      <div class="bg-surface-container-low rounded-3xl p-8 lg:p-10 border border-outline/10 hover:border-primary/30 transition-colors flex flex-col group lg:col-span-2">
        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:-translate-y-1 group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-3xl text-primary" data-icon="forest">forest</span>
        </div>
        <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">Zero-Cost Sustainability</h3>
        <p class="text-on-surface-variant leading-relaxed flex-grow max-w-3xl">
          Knowledge should be free, and so should its platform. Architected entirely on free, open-source infrastructure (GitHub Pages, Actions, and Discussions), this project is built to outlast us without the burden of server or hosting costs.
        </p>
      </div>

      <!-- Pillar 5 -->
      <div class="bg-surface-container-low rounded-3xl p-8 lg:p-10 border border-outline/10 hover:border-primary/30 transition-colors flex flex-col group">
        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:-translate-y-1 group-hover:scale-105 transition-all">
          <span class="material-symbols-outlined text-3xl text-primary" data-icon="data_object">data_object</span>
        </div>
        <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">Content Over Container</h3>
        <p class="text-on-surface-variant leading-relaxed flex-grow">
          Our schema is designed to make data structured and machine-readable, ensuring the focus remains on delivering the best learning experience.
        </p>
      </div>
    </div>
  </section>

  <!-- How to Contribute Workflow -->
  <section class="py-32 px-8 md:px-24 bg-surface-container-lowest border-t border-outline-variant/20">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20">
        <h2 class="font-headline text-4xl md:text-5xl font-bold tracking-tight mb-6 text-on-surface">The Contribution Journey</h2>
        <p class="text-xl text-on-surface-variant max-w-2xl mx-auto">We've designed a path that takes you from complete beginner to open-source contributor.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <!-- Connecting Line -->
        <div class="hidden md:block absolute top-12 left-[16%] right-[16%] h-0.5 bg-outline-variant/30 z-0"></div>

        <div class="relative z-10 flex flex-col items-center text-center group">
          <div class="w-24 h-24 rounded-full bg-surface border-4 border-surface-container shadow-md flex items-center justify-center mb-6 group-hover:border-primary/50 transition-colors">
            <span class="font-headline text-2xl font-bold text-on-surface">1</span>
          </div>
          <h3 class="text-xl font-bold mb-3 text-on-surface">Just a Fork</h3>
          <p class="text-on-surface-variant">Contribute with your notes or summaries into as simple as the process of forking to share your insights instantly.</p>
        </div>

        <div class="relative z-10 flex flex-col items-center text-center mt-12 md:mt-0 group">
          <div class="w-24 h-24 rounded-full bg-primary text-on-primary border-4 border-surface shadow-md flex items-center justify-center mb-6 group-hover:scale-105 transition-transform">
            <span class="font-headline text-2xl font-bold">2</span>
          </div>
          <h3 class="text-xl font-bold mb-3 text-on-surface">Peer Review</h3>
          <p class="text-on-surface-variant">Your submission enters GitHub as PR where peers review, refine, format, and structure the content together.</p>
        </div>

        <div class="relative z-10 flex flex-col items-center text-center mt-12 md:mt-0 group">
          <div class="w-24 h-24 rounded-full bg-surface border-4 border-surface-container shadow-md flex items-center justify-center mb-6 group-hover:border-primary/50 transition-colors">
            <span class="font-headline text-2xl font-bold text-on-surface">3</span>
          </div>
          <h3 class="text-xl font-bold mb-3 text-on-surface">Pull Request</h3>
          <p class="text-on-surface-variant">The structured content is merged into the repository via a PR, immortalizing your contribution in the commons.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Statistics -->
  <section class="bg-surface-container py-20 px-8 md:px-24">
    <div class="max-w-7xl mx-auto flex flex-wrap items-center justify-around gap-12">
      <div class="text-center">
        <div class="text-5xl md:text-6xl font-headline font-light text-primary mb-2">100%</div>
        <div class="font-label text-xs uppercase tracking-widest text-on-surface-variant font-bold">Free & Open Source</div>
      </div>
      <div class="w-px h-16 bg-outline-variant/30 hidden md:block"></div>
      <div class="text-center">
        <div class="text-5xl md:text-6xl font-headline font-light text-primary mb-2">∞</div>
        <div class="font-label text-xs uppercase tracking-widest text-on-surface-variant font-bold">Community Revisions</div>
      </div>
      <div class="w-px h-16 bg-outline-variant/30 hidden md:block"></div>
      <div class="text-center">
        <div class="text-5xl md:text-6xl font-headline font-light text-primary mb-2">24/7</div>
        <div class="font-label text-xs uppercase tracking-widest text-on-surface-variant font-bold">Accessible Knowledge</div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-32 px-8 md:px-24 flex flex-col items-center text-center bg-surface relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-primary/5 to-transparent pointer-events-none"></div>
    <h2 class="font-headline text-5xl md:text-6xl font-bold tracking-tighter text-on-surface mb-8 max-w-3xl relative z-10">
      Ready to join the collective?
    </h2>
    <p class="text-on-surface-variant font-body text-xl mb-12 max-w-2xl relative z-10">
      Whether you're here to learn from others or share what you know, your journey starts here.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 relative z-10">
      <a class="bg-primary text-on-primary px-10 py-5 rounded-xl font-bold tracking-tight hover:bg-primary/90 transition-all shadow-lg shadow-primary/20 flex items-center gap-2" href={`${import.meta.env.BASE_URL}/docs`}>
        Access the Database
        <span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span>
      </a>
      <a class="bg-surface-container border border-outline text-on-surface px-10 py-5 rounded-xl font-bold tracking-tight hover:bg-surface-container-highest transition-all flex items-center gap-2" href="https://github.com/ID-Brains/id-db/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener noreferrer">
        Learn How to Contribute
      </a>
    </div>
  </section>

  <AppearanceWidget />
</MainLayout>
