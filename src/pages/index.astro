---
import MainLayout from "../layouts/MainLayout.astro";
import AppearanceWidget from "../components/AppearanceWidget.astro";
---

<MainLayout title="College Knowledge Base | Real Notes Archive">
  <header
    class="relative min-h-[870px] flex flex-col justify-center px-8 md:px-24"
  >
    <div class="grid grid-cols-12 gap-8">
      <div class="col-span-12 lg:col-span-8">
        <p
          class="font-label text-xs uppercase tracking-[0.3em] text-primary mb-6 opacity-80"
        >
          Student Repository
        </p>
        <h1
          class="font-headline text-7xl md:text-9xl font-bold tracking-tighter text-on-surface mb-12 leading-[0.9]"
        >
          Real Notes. <br />Real Results.
        </h1>
        <p
          class="text-on-surface-variant text-lg max-w-2xl mb-10 leading-relaxed"
        >
          Access organized lecture notes, summaries, and practical reports
          shared by students across departments.
        </p>
        <div class="flex flex-col sm:flex-row gap-6">
          <a
            class="bg-gradient-to-br from-primary to-primary-container text-white px-8 py-4 rounded-md font-medium text-lg hover:shadow-lg transition-all active:scale-95 flex items-center justify-center gap-3"
            href={`${import.meta.env.BASE_URL}/docs`}
          >
            Browse Notes
            <span
              class="material-symbols-outlined text-lg"
              data-icon="arrow_forward">arrow_forward</span
            >
          </a>
          <a
            class="border border-outline-variant/15 text-primary px-8 py-4 rounded-md font-medium text-lg hover:bg-surface-container-low transition-all active:scale-95 flex items-center justify-center gap-3"
            href={`${import.meta.env.BASE_URL}/docs`}
          >
            Share Your Notes
          </a>
        </div>
      </div>
    </div>
    <div
      class="absolute right-0 bottom-12 hidden lg:block w-1/3 h-2/3 bg-surface-container-low rounded-tl-full overflow-hidden opacity-80"
    >
      <img
        alt="University students studying in a modern library"
        class="w-full h-full object-cover grayscale opacity-40 mix-blend-multiply"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuD8581NGnSX-YCE5dnGka737hubjYXCaIru_b6VF95nop2VnO9yyruOjZC4f6AlFnU5WeGEbxTOMz13-xsVVTbIm7Nk_EfJ3BT1EttV7JzKfPsUneYDT47EGyNuDccbP9z8y7-7yPSwqCIFAsw7oXBgjzaZpWBpQcYLkpidVsWI7xWku-6OgUZkzte8ZzVuAUJMa0sy-IeSmJ71xSBWx2k182Cejze62rcmfRIpjRX5DJb3FAIYLLQteA-O0ybV5uM4QwNFt6G8worD"
      />
    </div>
  </header>
  <section class="px-8 md:px-24 py-32 bg-surface">
    <div
      class="flex flex-col md:flex-row justify-between items-end mb-16 gap-4"
    >
      <div class="max-w-xl">
        <h2
          class="font-headline text-4xl font-bold tracking-tight mb-4 text-on-background"
        >
          Featured Content
        </h2>
        <p class="text-on-surface-variant font-body leading-relaxed">
          Explore practical course materials prepared by students and reviewed
          for clarity, structure, and relevance.
        </p>
      </div>
      <a
        class="font-label text-sm font-semibold text-primary-container border-b-2 border-primary-container pb-1"
        href={`${import.meta.env.BASE_URL}/docs`}>View All Documents</a
      >
    </div>
    <div
      class="grid grid-cols-1 md:grid-cols-4 grid-rows-2 gap-4 h-auto md:h-[600px]"
    >
      <a
        class="md:col-span-2 md:row-span-2 bg-surface-container-lowest rounded-xl p-10 flex flex-col justify-between hover:bg-surface-bright hover:shadow-2xl transition-all group cursor-pointer"
        href={`${import.meta.env.BASE_URL}/docs`}
      >
        <div>
          <div
            class="inline-flex items-center px-3 py-1 rounded-full bg-secondary-container text-on-secondary-container text-xs font-label font-bold mb-6"
          >
            TOP PICK
          </div>
          <h3 class="font-headline text-3xl font-bold text-primary mb-4">
            [nice Place holder]
          </h3>
          <p class="text-on-surface-variant text-sm line-clamp-3">
            Lorem ipsum dolor sit amet consectetur adipisicing elit. Ad dolor
            recusandae minus laudantium, ratione doloremque soluta iste? Impedit
            nam provident. Quis quaerat ipsam quidem rem, officiis reiciendis.
          </p>
        </div>
        <div class="flex items-center gap-2 text-primary font-bold">
          Open collection <span
            class="material-symbols-outlined group-hover:translate-x-1 transition-transform"
            data-icon="east">east</span
          >
        </div>
      </a>
      <div
        class="md:col-span-2 bg-surface-container-low rounded-xl relative overflow-hidden group"
      >
        <img
          alt="Data visualization dashboard for student analysis reports"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuAoWu2WP4_kavvls41IyEFEt_bCMhdvOK50fTv_SJeFb_lTMM_uIBsQPqmtqyH_tpNSxF21J3Zu1B2dgTjmAH_rAxYWiLfjT_wRRTgFOHSKvBXLpHOXowCAdDvdZFU1PstMRt5X67OS0zypf_ByZk9A0086xdyrU_wHFyDKBYxq3tZAiJyUC8KO0zBlJMKN-IYwSP_5YGraFJtA7rIJMs-gnhHQHbikiAsUt2VzJUafFwMUsp1C_0F9UXuQfnGzZFF8HqdATbe9d_fS"
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent"
        >
        </div>
        <div class="absolute bottom-6 left-6 text-white">
          <p class="font-label text-xs uppercase tracking-widest opacity-80">
            Latest Upload
          </p>
          <h4 class="font-headline text-xl font-bold">[Place holder]</h4>
        </div>
      </div>
      <div
        class="bg-surface-container-lowest rounded-xl p-6 border border-outline-variant/15 hover:border-primary/40 transition-colors"
      >
        <span
          class="material-symbols-outlined text-primary-container mb-4"
          data-icon="menu_book">menu_book</span
        >
        <h5 class="font-bold text-sm mb-2">Summaries</h5>
        <p class="text-xs text-on-surface-variant">
          Quick revision sheets from actual lectures and labs.
        </p>
      </div>
      <div
        class="bg-surface-container-lowest rounded-xl p-6 border border-outline-variant/15 hover:border-primary/40 transition-colors"
      >
        <span
          class="material-symbols-outlined text-primary-container mb-4"
          data-icon="school">school</span
        >
        <h5 class="font-bold text-sm mb-2">Course Notes</h5>
        <p class="text-xs text-on-surface-variant">
          Structured notes by subject, year, and term for easy access.
        </p>
      </div>
    </div>
  </section>
  <section class="bg-surface-container-low py-16 px-8 md:px-24">
    <div class="flex flex-wrap items-center justify-center gap-12">
      <div class="flex items-center gap-4">
        <span class="text-5xl font-headline font-light text-primary">0+</span>
        <div class="flex flex-col">
          <span
            class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant"
            >Published Notes</span
          >
          <div
            class="bg-surface-container-highest px-3 py-1 rounded-full flex items-center gap-2 mt-1"
          >
            <span
              class="material-symbols-outlined text-sm"
              data-icon="description">description</span
            >
            <span class="font-label text-xs font-bold">Growing Daily</span>
          </div>
        </div>
      </div>
      <div class="w-px h-12 bg-outline-variant hidden md:block"></div>
      <div class="flex items-center gap-4">
        <span class="text-5xl font-headline font-light text-primary">40+</span>
        <div class="flex flex-col">
          <span
            class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant"
            >Subjects</span
          >
          <div
            class="bg-tertiary-container px-3 py-1 rounded-full flex items-center gap-2 mt-1 text-on-tertiary-container"
          >
            <span class="material-symbols-outlined text-sm" data-icon="category"
              >category</span
            >
            <span class="font-label text-xs font-bold">Cross-Discipline</span>
          </div>
        </div>
      </div>
      <div class="w-px h-12 bg-outline-variant hidden md:block"></div>
      <div class="flex items-center gap-4">
        <span class="text-5xl font-headline font-light text-primary">24/7</span>
        <div class="flex flex-col">
          <span
            class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant"
            >Access</span
          >
          <div
            class="bg-secondary-container px-3 py-1 rounded-full flex items-center gap-2 mt-1 text-on-secondary-container"
          >
            <span class="material-symbols-outlined text-sm" data-icon="public"
              >public</span
            >
            <span class="font-label text-xs font-bold">Always Online</span>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="py-32 px-8 md:px-24 flex flex-col items-center text-center">
    <h2
      class="font-headline text-5xl font-bold tracking-tighter text-on-background mb-8 max-w-2xl"
    >
      Study better with community-powered materials.
    </h2>
    <p class="text-on-surface-variant font-body text-lg mb-12 max-w-xl">
      Discover high-quality notes, contribute your own files, and help build the
      most useful student knowledge hub.
    </p>
    <a
      class="bg-primary text-white px-10 py-5 rounded-md font-bold tracking-tight hover:bg-primary-container transition-all"
      href={`${import.meta.env.BASE_URL}/docs`}>Start Exploring</a
    >
  </section>
  <AppearanceWidget />
</MainLayout>
