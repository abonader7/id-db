---

const pathname = Astro.url.pathname;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
const isHome = pathname === `${base}/` || pathname === base;
const isDocs = pathname.startsWith(`${base}/docs`);
---

<nav class="fixed top-0 w-full z-40 border-b border-outline-variant/40 bg-surface-container-low/80 font-headline tracking-tight backdrop-blur-md" data-navbar>
  <div class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-4 md:px-8">
    <a class="text-xl font-bold tracking-tighter text-on-surface" href={`${base}/`}>project-hikma</a>

    <div class="hidden items-center space-x-8 md:flex">
      <a class={`transition-colors ${isHome ? 'border-b-2 border-primary pb-1 text-primary' : 'text-on-surface-variant hover:text-primary'}`} href={`${base}/`}>Home</a>
      <a class={`transition-colors ${isDocs ? 'border-b-2 border-primary pb-1 text-primary' : 'text-on-surface-variant hover:text-primary'}`} href={`${base}/docs`}>Docs</a>
    </div>

    <div class="flex items-center gap-3 md:gap-4">
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-outline-variant/45 text-on-surface-variant transition-colors hover:border-primary/50 hover:text-primary md:hidden"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav-panel"
        data-nav-trigger
      >
        <span aria-hidden="true" class="material-symbols-outlined transition-transform duration-300" data-nav-icon>menu</span>
      </button>
    </div>
  </div>

  <!-- Overlay Backdrop -->
  <div class="fixed inset-0 w-screen h-screen bg-black/40 backdrop-blur-[2px] z-[-1] hidden md:hidden transition-opacity duration-300 opacity-0" data-nav-overlay aria-hidden="true"></div>

  <!-- Off-Canvas Sidebar Drawer -->
  <div class="fixed top-0 right-0 h-screen w-[80vw] max-w-[320px] bg-surface-container-lowest z-50 shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out md:hidden flex flex-col pt-24 px-6 gap-6" id="mobile-nav-panel" data-nav-panel>
    <div class="flex flex-col gap-3">
      <p class="font-label text-xs uppercase tracking-widest text-on-surface-variant font-bold mb-2 pl-2">Navigation</p>
      <a class={`flex items-center gap-3 rounded-2xl px-4 py-3.5 transition-colors ${isHome ? 'bg-primary/10 text-primary font-bold' : 'text-on-surface hover:bg-surface-container hover:text-primary'}`} href={`${base}/`} data-nav-link>
        <span class="material-symbols-outlined text-[1.2rem]">home</span> Home
      </a>
      <a class={`flex items-center gap-3 rounded-2xl px-4 py-3.5 transition-colors ${isDocs ? 'bg-primary/10 text-primary font-bold' : 'text-on-surface hover:bg-surface-container hover:text-primary'}`} href={`${base}/docs`} data-nav-link>
        <span class="material-symbols-outlined text-[1.2rem]">menu_book</span> Docs
      </a>
    </div>
  </div>
</nav>

<script>
  const navRoot = document.querySelector('[data-navbar]');

  if (navRoot) {
    const trigger = navRoot.querySelector('[data-nav-trigger]');
    const panel = navRoot.querySelector('[data-nav-panel]');
    const overlay = navRoot.querySelector('[data-nav-overlay]');
    const links = navRoot.querySelectorAll('[data-nav-link]');
    const icon = navRoot.querySelector('[data-nav-icon]');

    if (trigger instanceof HTMLButtonElement && panel instanceof HTMLElement && overlay instanceof HTMLElement) {
      const setOpenState = (open: boolean) => {
        trigger.setAttribute('aria-expanded', String(open));

        if (open) {
          overlay.classList.remove('hidden');
          // Lock body scroll
          document.body.style.overflow = 'hidden';
          if(icon) icon.textContent = 'close';

          requestAnimationFrame(() => {
            overlay.classList.remove('opacity-0');
            panel.classList.remove('translate-x-full');
          });
        } else {
          overlay.classList.add('opacity-0');
          panel.classList.add('translate-x-full');
          document.body.style.overflow = '';
          if(icon) icon.textContent = 'menu';

          setTimeout(() => {
            overlay.classList.add('hidden');
          }, 300);
        }
      };

      trigger.addEventListener('click', () => {
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        setOpenState(!isOpen);
      });

      overlay.addEventListener('click', () => setOpenState(false));

      links.forEach((link) => {
        link.addEventListener('click', () => setOpenState(false));
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && trigger.getAttribute('aria-expanded') === 'true') {
          setOpenState(false);
          trigger.focus();
        }
      });
    }
  }
</script>
